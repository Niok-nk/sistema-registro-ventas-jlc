---
import Card from "../Card.astro";
import VentasFilters from "./ventas/VentasFilters.astro";
import VentasStates from "./ventas/VentasStates.astro";
import VentasTable from "./ventas/VentasTable.astro";
import UserProfilePopup from "../usuarios/UserProfilePopup.astro";
---

<Card title="Historial de Ventas">
  <VentasFilters />

  <div class="sales-table-wrapper">
    <VentasStates />
    <VentasTable />
  </div>

  <!-- Controles de paginación -->
  <div id="pagination-controls" style="display:none" class="pagination">
    <button id="prev-page" class="page-btn" disabled>
      <svg
        viewBox="0 0 20 20"
        fill="currentColor"
        style="width:1rem;height:1rem"
        ><path
          fill-rule="evenodd"
          d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
          clip-rule="evenodd"></path></svg
      >
      Anterior
    </button>
    <span id="page-indicator" class="page-info">Página 1 de 1</span>
    <button id="next-page" class="page-btn">
      Siguiente
      <svg
        viewBox="0 0 20 20"
        fill="currentColor"
        style="width:1rem;height:1rem"
        ><path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"></path></svg
      >
    </button>
  </div>
</Card>

<!-- User Profile Popup -->
<UserProfilePopup />

<style>
  /* Table Wrapper - único estilo que se queda aquí */
  .sales-table-wrapper {
    overflow-x: auto;
    min-height: 300px;
    scrollbar-color: #9d9d9d59 transparent;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1rem 0 0.5rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.5rem;
  }
  .page-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-card);
    color: var(--color-text-main);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .page-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .page-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .page-info {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    min-width: 110px;
    text-align: center;
  }
</style>

<script is:inline>
  // Helper: URL firmada efímera para archivos
  async function openSignedFile(file, type) {
    const AB =
      window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"
        ? "http://localhost:8000"
        : window.location.origin + "/api";
    try {
      const res = await fetch(`${AB}/files/signed_url.php`, {
        method: "POST",
        credentials: "include",
          headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ file, type }),
      });
      const data = await res.json();
      if (data.signed_url) window.open(data.signed_url, "_blank", "noopener,noreferrer");
      else alert("No se pudo obtener el enlace del archivo.");
    } catch (e) {
      alert("Error al abrir el archivo: " + e.message);
    }
  }

  (function () {
    const API_BASE =
      window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"
        ? "http://localhost:8000"
        : window.location.origin + "/api";

    let allSales = [];
    let allProducts = [];
    let currentFilteredSales = []; // Array con ventas filtradas actualmente
    let currentPage = 1;
    const ROWS_PER_PAGE = 100;

    // Export elements
    const exportBtn = document.getElementById("export-btn");
    const exportMenu = document.getElementById("export-menu");
    const exportCount = document.getElementById("export-count");

    // Elementos DOM
    const loadingState = document.getElementById("loading-state");
    const errorState = document.getElementById("error-state");
    const emptyState = document.getElementById("empty-state");
    const salesTable = document.getElementById("sales-table");
    const salesTbody = document.getElementById("sales-tbody");
    const retryBtn = document.getElementById("retry-btn");
    const filterBtn = document.getElementById("filter-btn");
    const searchInput = document.getElementById("search");
    const productFilter = document.getElementById("filtro-producto");
    const fechaDesde = document.getElementById("fecha-desde");
    const fechaHasta = document.getElementById("fecha-hasta");
    const estadoFilter = document.getElementById("filtro-estado");

    // Funciones de estado
    function showLoading() {
      loadingState.style.display = "flex";
      errorState.style.display = "none";
      emptyState.style.display = "none";
      salesTable.style.display = "none";
    }

    function showError() {
      loadingState.style.display = "none";
      errorState.style.display = "flex";
      emptyState.style.display = "none";
      salesTable.style.display = "none";
    }

    function showEmpty() {
      loadingState.style.display = "none";
      errorState.style.display = "none";
      emptyState.style.display = "flex";
      salesTable.style.display = "none";
    }

    function showTable() {
      loadingState.style.display = "none";
      errorState.style.display = "none";
      emptyState.style.display = "none";
      salesTable.style.display = "table";
    }

    // Cargar productos para filtro
    async function loadProducts() {
      try {
        const response = await fetch(`${API_BASE}/products/list.php`, {
          credentials: "include",
          headers: { },
        });
        const data = await response.json();

        if (data.status === 200 && data.data) {
          allProducts = data.data;
          populateProductFilter();
        }
      } catch (error) {
        console.error("Error cargando productos:", error);
      }
    }

    function populateProductFilter() {
      const currentValue = productFilter.value;
      productFilter.innerHTML = '<option value="">Todos los productos</option>';

      // Solo mostrar productos activos
      allProducts
        .filter((product) => product.activo == 1)
        .forEach((product) => {
          const option = document.createElement("option");
          option.value = product.id;
          option.textContent = product.modelo;
          productFilter.appendChild(option);
        });

      productFilter.value = currentValue;
    }

    // Cargar ventas
    async function loadSales() {
      showLoading();

      try {
        const response = await fetch(`${API_BASE}/sales/list.php`, {
          method: "GET",
          credentials: "include",
          headers: {
          },
        });

        const data = await response.json();

        if (data.status === 200 && data.data) {
          allSales = data.data;
          renderSales(allSales);
        } else if (response.status === 401) {
          localStorage.removeItem("user"); localStorage.removeItem("userRole");
          window.location.href = "/login";
        } else {
          throw new Error(data.message || "Error desconocido");
        }
      } catch (error) {
        console.error("Error cargando ventas:", error);
        showError();
      }
    }

    // Renderizar ventas (muestra solo la página actual)
    function renderSales(sales) {
      currentFilteredSales = sales;
      currentPage = 1;
      renderPage();
    }

    function renderPage() {
      const sales = currentFilteredSales;
      if (!sales || sales.length === 0) {
        showEmpty();
        updatePagination(0);
        return;
      }

      const totalPages = Math.ceil(sales.length / ROWS_PER_PAGE);
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * ROWS_PER_PAGE;
      const pageSlice = sales.slice(start, start + ROWS_PER_PAGE);

      salesTbody.innerHTML = "";

      // Verificar si el usuario es administrador
      const userRole = localStorage.getItem("userRole");
      const isAdmin = userRole === "admin" || userRole === "administrador";

      pageSlice.forEach((sale) => {
        const row = document.createElement("tr");

        // Columna de foto
        const photoBtn = sale.foto_factura
          ? `<button class="btn-view-photo" data-photo="${sale.foto_factura}" title="Ver foto">
               <svg viewBox="0 0 20 20" fill="currentColor" style="width:1.25rem;height:1.25rem">
                 <path fill-rule="evenodd" d="M1 5.25A2.25 2.25 0 013.25 3h13.5A2.25 2.25 0 0119 5.25v9.5A2.25 2.25 0 0116.75 17H3.25A2.25 2.25 0 011 14.75v-9.5zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 00.75-.75v-2.69l-2.22-2.219a.75.75 0 00-1.06 0l-1.91 1.909-.48-.48a.75.75 0 00-1.06 0l-5.18 5.182H2.5v-3.578l3.22-3.22a.75.75 0 011.06 0l1.47 1.47 1.91-1.909a.75.75 0 011.06 0l2.97 2.97zM10 8a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
               </svg>
             </button>`
          : `<span style="color:var(--color-text-secondary);font-size:0.875rem">Sin foto</span>`;

        // Estado: Selector para admin, badge para usuarios
        const estadoHTML = isAdmin
          ? `<select class="status-selector" data-sale-id="${sale.id}" data-current-status="${sale.estado || "pendiente"}">
               <option value="pendiente" ${(sale.estado || "pendiente") === "pendiente" ? "selected" : ""}>Pendiente</option>
               <option value="aprobada" ${sale.estado === "aprobada" ? "selected" : ""}>Aprobada</option>
               <option value="rechazada" ${sale.estado === "rechazada" ? "selected" : ""}>Rechazada</option>
             </select>`
          : `<span class="status-badge status-${(sale.estado || "pendiente").toLowerCase()}">${sale.estado || "Pendiente"}</span>`;

        row.innerHTML = `
                <td>${sale.id}</td>
                <td>${sale.fecha_venta || "N/A"}</td>
                <td>${sale.numero_factura || "N/A"}</td>
                <td>${sale.modelo_producto || sale.desc_producto || "N/A"}</td>
                <td>${sale.numero_serie || "N/A"}</td>
                <td class="asesor-cell">
                  <div class="clickable-user" data-user-id="${sale.usuario_id}" style="font-weight:500">${sale.nombre_asesor || ""} ${sale.apellido_asesor || ""}</div>
                  <div class="clickable-user" data-user-id="${sale.usuario_id}" style="font-size:0.75rem;color:var(--color-text-secondary)">CC: ${sale.cedula_asesor || "N/A"}</div>
                </td>
                <td>${sale.nombre_distribuidor || "N/A"}</td>
                <td>${estadoHTML}</td>
                <td>${photoBtn}</td>
                <td>
                  ${
                    isAdmin
                      ? `<select
                        class="obs-selector"
                        data-sale-id="${sale.id}"
                        ${sale.estado !== "rechazada" ? "disabled" : ""}
                        style="font-size:0.72rem;padding:0.2rem 0.3rem;border-radius:var(--radius-sm);border:1px solid var(--color-border);background:var(--color-bg-card);color:var(--color-text-main);width:100%;max-width:170px;${sale.estado !== "rechazada" ? "opacity:0.35;cursor:not-allowed" : ""}"
                      >
                        <option value="">-- Sin observación --</option>
                        <option value="Número de serie incorrecto o inválido" ${sale.observaciones === "Número de serie incorrecto o inválido" ? "selected" : ""}>N° serie incorrecto o inválido</option>
                        <option value="Factura sin código QR o CUFE (DIAN)" ${sale.observaciones === "Factura sin código QR o CUFE (DIAN)" ? "selected" : ""}>Sin QR o CUFE (DIAN)</option>
                        <option value="Venta sin registro en la DIAN" ${sale.observaciones === "Venta sin registro en la DIAN" ? "selected" : ""}>Sin registro DIAN</option>
                      </select>`
                      : sale.estado === "rechazada" && sale.observaciones
                        ? `<span style="font-size:0.72rem;color:#fc8181">${sale.observaciones}</span>`
                        : `<span style="font-size:0.72rem;color:var(--color-text-secondary)">-</span>`
                  }
                </td>
                <td class="admin-only-column" style="display: none;">
                  <button class="btn-delete-sale" data-sale-id="${sale.id}" data-sale-invoice="${sale.numero_factura}" title="Eliminar venta">
                    <svg viewBox="0 0 20 20" fill="currentColor" style="width:1rem;height:1rem">
                      <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
                    </svg>
                  </button>
                </td>
            `;
        salesTbody.appendChild(row);
      });

      // Event listeners para botones de fotos
      document.querySelectorAll(".btn-view-photo").forEach((btn) => {
        btn.addEventListener("click", function () {
          const photoPath = this.getAttribute("data-photo");
          if (photoPath) {
            const filename = photoPath.split("/").pop();
            openSignedFile(filename, "factura");
          }
        });
      });

      // Event listeners para selectores de estado (solo para admin)
      if (isAdmin) {
        document.querySelectorAll(".status-selector").forEach((select) => {
          select.addEventListener("change", async function () {
            const saleId = this.getAttribute("data-sale-id");
            const newStatus = this.value;
            const currentStatus = this.getAttribute("data-current-status");

            if (newStatus === currentStatus) return;

            if (!confirm(`¿Cambiar estado de la venta a "${newStatus}"?`)) {
              // Restaurar valor anterior
              this.value = currentStatus;
              return;
            }

            await updateSaleStatus(saleId, newStatus, this);

            // Actualizar el select de observaciones de esta fila
            const row = this.closest("tr");
            const obsSel = row?.querySelector(".obs-selector");
            if (obsSel) {
              const isRejected = newStatus === "rechazada";
              obsSel.disabled = !isRejected;
              obsSel.style.opacity = isRejected ? "1" : "0.35";
              obsSel.style.cursor = isRejected ? "auto" : "not-allowed";
              if (!isRejected) obsSel.value = "";
            }
          });
        });

        // Event listeners para el selector de observaciones
        document.querySelectorAll(".obs-selector").forEach((select) => {
          select.addEventListener("change", async function () {
            const saleId = this.getAttribute("data-sale-id");
            const observacion = this.value;

            // Obtener el estado actual de la misma fila
            const row = this.closest("tr");
            const statusSel = row?.querySelector(".status-selector");
            const estado = statusSel ? statusSel.value : "rechazada";
            try {
              const res = await fetch(`${API_BASE}/sales/update_status.php`, {
                method: "POST",
                credentials: "include",
          headers: {
                  "Content-Type": "application/json",
                },
                body: JSON.stringify({
                  id: saleId,
                  estado,
                  observaciones: observacion,
                }),
              });
              const data = await res.json();
              if (data.status !== 200) {
                alert("Error al guardar observación: " + (data.message || ""));
              } else {
                // ✅ Actualizar en memoria para que filtrar no revierta el valor
                const id = parseInt(saleId);
                const target = allSales.find((s) => s.id === id);
                if (target) target.observaciones = observacion;
                const target2 = currentFilteredSales.find((s) => s.id === id);
                if (target2) target2.observaciones = observacion;
              }
            } catch (e) {
              console.error("Error guardando observación:", e);
            }
          });
        });
      }

      // Event listeners para botones de eliminar (solo para admin)
      if (isAdmin) {
        // Mostrar columna de acciones
        document.querySelectorAll(".admin-only-column").forEach((col) => {
          col.style.display = "table-cell";
        });

        document.querySelectorAll(".btn-delete-sale").forEach((btn) => {
          btn.addEventListener("click", async function () {
            const saleId = this.getAttribute("data-sale-id");
            const invoiceNum = this.getAttribute("data-sale-invoice");

            if (
              confirm(
                `¿Estás seguro de eliminar la venta N° ${invoiceNum}?\n\nEsta acción NO se puede deshacer.`,
              )
            ) {
              await deleteSale(saleId);
            }
          });
        });
      }

      // Event delegation para celdas clickeables (nombre y cédula del asesor)
      salesTbody.addEventListener("click", (e) => {
        const clickableElement = e.target.closest(".clickable-user");
        if (clickableElement && window.UserProfilePopup) {
          const userId = clickableElement.getAttribute("data-user-id");
          if (userId) {
            window.UserProfilePopup.show(parseInt(userId));
          }
        }
      });

      showTable();
      updatePagination(currentFilteredSales.length);
    }

    // ── Paginación ────────────────────────────────────────────
    const paginationEl = document.getElementById("pagination-controls");
    const prevBtn = document.getElementById("prev-page");
    const nextBtn = document.getElementById("next-page");
    const pageIndicator = document.getElementById("page-indicator");

    function updatePagination(total) {
      const totalPages = Math.ceil(total / ROWS_PER_PAGE) || 1;
      if (paginationEl)
        paginationEl.style.display = total > ROWS_PER_PAGE ? "flex" : "none";
      if (pageIndicator)
        pageIndicator.textContent = `Página ${currentPage} de ${totalPages}`;
      if (prevBtn) prevBtn.disabled = currentPage <= 1;
      if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    }

    if (prevBtn)
      prevBtn.addEventListener("click", () => {
        if (currentPage > 1) {
          currentPage--;
          renderPage();
        }
      });
    if (nextBtn)
      nextBtn.addEventListener("click", () => {
        const totalPages = Math.ceil(
          currentFilteredSales.length / ROWS_PER_PAGE,
        );
        if (currentPage < totalPages) {
          currentPage++;
          renderPage();
        }
      });

    // Función para actualizar estado de venta
    async function updateSaleStatus(saleId, newStatus, selectElement) {
      try {
        const response = await fetch(`${API_BASE}/sales/update_status.php`, {
          method: "POST",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            id: parseInt(saleId),
            estado: newStatus,
          }),
        });

        const result = await response.json();

        if (result.status === 200) {
          alert("✅ Estado actualizado exitosamente");
          // Actualizar el atributo data-current-status
          selectElement.setAttribute("data-current-status", newStatus);
          // Recargar ventas para reflejar cambios
          loadSales();
        } else {
          alert("❌ Error: " + result.message);
          // Restaurar valor anterior
          selectElement.value = selectElement.getAttribute(
            "data-current-status",
          );
        }
      } catch (error) {
        alert("❌ Error al actualizar: " + error.message);
        // Restaurar valor anterior
        selectElement.value = selectElement.getAttribute("data-current-status");
      }
    }

    // Función para eliminar venta
    async function deleteSale(saleId) {
      try {
        const response = await fetch(`${API_BASE}/sales/delete.php`, {
          method: "DELETE",
          credentials: "include",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ id: parseInt(saleId) }),
        });

        const result = await response.json();

        if (result.status === 200) {
          alert("✅ Venta eliminada exitosamente");
          // Recargar ventas
          loadSales();
        } else {
          alert("❌ Error: " + result.message);
        }
      } catch (error) {
        alert("❌ Error al eliminar: " + error.message);
      }
    }

    // Filtrar ventas
    function filterSales() {
      const search = searchInput.value.toLowerCase();
      const productId = productFilter.value;
      const dateFrom = fechaDesde.value;
      const dateTo = fechaHasta.value;
      const estadoVal = estadoFilter ? estadoFilter.value : "";

      let filtered = allSales;

      // Filtro por búsqueda (factura, serie, asesor, cédula, ciudad, departamento)
      if (search) {
        filtered = filtered.filter(
          (sale) =>
            // Número de factura
            (sale.numero_factura || "").toLowerCase().includes(search) ||
            // Número de serie
            (sale.numero_serie || "").toLowerCase().includes(search) ||
            // Nombre completo del asesor
            `${sale.nombre_asesor || ""} ${sale.apellido_asesor || ""}`
              .trim()
              .toLowerCase()
              .includes(search) ||
            // Cédula del asesor
            (sale.cedula_asesor || "").toLowerCase().includes(search) ||
            // Ciudad del asesor (ciudad de residencia)
            (sale.ciudad_residencia || "").toLowerCase().includes(search) ||
            // Departamento del asesor
            (sale.departamento || "").toLowerCase().includes(search) ||
            // Distribuidor (opcional, ya que también es relevante)
            (sale.nombre_distribuidor || "").toLowerCase().includes(search),
        );
      }

      // Filtro por producto
      if (productId) {
        filtered = filtered.filter(
          (sale) => String(sale.producto_id) === String(productId),
        );
      }

      // Filtro por rango de fechas
      if (dateFrom || dateTo) {
        filtered = filtered.filter((sale) => {
          if (!sale.fecha_venta) return false;

          const saleDate = new Date(sale.fecha_venta);

          if (dateFrom) {
            const fromDate = new Date(dateFrom);
            if (saleDate < fromDate) return false;
          }

          if (dateTo) {
            const toDate = new Date(dateTo);
            // Agregar un día para incluir toda la fecha "hasta"
            toDate.setDate(toDate.getDate() + 1);
            if (saleDate >= toDate) return false;
          }

          return true;
        });
      }

      // Filtro por estado
      if (estadoVal) {
        filtered = filtered.filter(
          (sale) => (sale.estado || "pendiente").toLowerCase() === estadoVal,
        );
      }

      currentFilteredSales = filtered; // Guardar para exportación
      renderSales(filtered);
      updateExportButton(); // Actualizar contador
    }

    // Event listeners
    if (retryBtn) {
      retryBtn.addEventListener("click", loadSales);
    }

    if (filterBtn) {
      filterBtn.addEventListener("click", filterSales);
    }

    // Búsqueda en tiempo real mientras se escribe
    if (searchInput) {
      searchInput.addEventListener("input", filterSales);
    }

    // Filtro de estado en tiempo real
    if (estadoFilter) {
      estadoFilter.addEventListener("change", filterSales);
    }

    // Filtrar automáticamente al cambiar producto
    if (productFilter) {
      productFilter.addEventListener("change", filterSales);
    }

    // Filtrar automáticamente al cambiar fechas
    if (fechaDesde) {
      fechaDesde.addEventListener("change", filterSales);
    }

    if (fechaHasta) {
      fechaHasta.addEventListener("change", filterSales);
    }

    // ===== FUNCIONES DE EXPORTACIÓN =====
    // Nota: Estas funciones se mantienen aquí porque <script is:inline>
    // no puede importar módulos ES6

    // Actualizar estado del botón de exportar
    function updateExportButton() {
      const count = currentFilteredSales.length;
      if (exportCount) exportCount.textContent = count;
      if (exportBtn) exportBtn.disabled = count === 0;
    }

    // Generar timestamp para nombres de archivo
    function getTimestamp() {
      const now = new Date();
      return now.toISOString().slice(0, 19).replace(/:/g, "-");
    }

    // Escapar valores para CSV
    function escapeCSV(value) {
      if (value === null || value === undefined) return "";
      const str = String(value);
      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
        return `"${str.replace(/"/g, '""')}"`;
      }
      return str;
    }

    // Obtener URLs firmadas para todas las ventas con foto (en paralelo)
    async function getSignedUrls(sales) {
      const salesWithPhoto = sales.filter((s) => s.foto_factura);
      const results = await Promise.allSettled(
        salesWithPhoto.map((sale) =>
          fetch(`${API_BASE}/files/signed_url.php`, {
            method: "POST",
            credentials: "include",
          headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ file: sale.foto_factura, type: "factura" }),
          })
            .then((r) => r.json())
            .then((d) => ({ id: sale.id, url: d.signed_url || "" }))
            .catch(() => ({ id: sale.id, url: "" }))
        )
      );
      const urlMap = {};
      results.forEach((r) => { if (r.status === "fulfilled") urlMap[r.value.id] = r.value.url; });
      return urlMap;
    }

    // Exportar a CSV
    async function exportToCSV(sales) {
      // Obtener URLs firmadas primero
      const urlMap = await getSignedUrls(sales);

      // 1. Headers
      const headers = [
        "ID",
        "Fecha Registro",
        "Fecha Venta",
        "N° Factura",
        "Producto",
        "N° Serie",
        "Asesor",
        "Cédula",
        "Nequi",
        "Distribuidor",
        "Estado",
        "Observaciones",
        "Link Foto",
      ];

      // 2. Datos
      const rows = sales.map((sale) => [
        sale.id || "",
        sale.created_at || "",
        sale.fecha_venta || "",
        sale.numero_factura || "",
        sale.modelo_producto || sale.desc_producto || "",
        sale.numero_serie || "",
        `${sale.nombre_asesor || ""} ${sale.apellido_asesor || ""}`.trim(),
        sale.cedula_asesor || "",
        sale.llave_breb || "",
        sale.nombre_distribuidor || "",
        sale.estado || "",
        sale.observaciones || "",
        urlMap[sale.id] || "",
      ]);
      // 3. Combinar en string CSV
      const csvContent = [
        headers.join(","),
        ...rows.map((row) => row.map(escapeCSV).join(",")),
      ].join("\n");

      // 4. Crear Blob y descargar (UTF-8 con BOM para Excel)
      const blob = new Blob(["\uFEFF" + csvContent], {
        type: "text/csv;charset=utf-8;",
      });

      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `ventas_${getTimestamp()}.csv`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);

      console.log(`Exportadas ${sales.length} ventas a CSV`);
    }

    // Exportar a Excel (todas las ventas filtradas, hoja única)
    async function exportToExcel(sales) {
      if (typeof XLSX === "undefined") {
        alert("Error: Librería de Excel no disponible");
        return;
      }

      // Generar URLs firmadas para todas las fotos en paralelo
      const urlMap = await getSignedUrls(sales);

      const data = [
        // Headers
        [
          "ID",
          "Fecha Registro",
          "Fecha Venta",
          "N° Factura",
          "Producto",
          "Código Producto",
          "N° Serie",
          "Asesor",
          "Cédula",
          "Nequi",
          "Distribuidor",
          "Estado",
          "Observaciones",
          "Link Foto",
        ],
        // Datos
        ...sales.map((sale) => [
          sale.id || "",
          sale.created_at || "",
          sale.fecha_venta || "",
          sale.numero_factura || "",
          sale.modelo_producto || sale.desc_producto || "",
          sale.codigo_producto || "",
          sale.numero_serie || "",
          `${sale.nombre_asesor || ""} ${sale.apellido_asesor || ""}`.trim(),
          sale.cedula_asesor || "",
          sale.llave_breb || "",
          sale.nombre_distribuidor || "",
          sale.estado || "",
          sale.observaciones || "",
          urlMap[sale.id] || "",
        ]),
      ];

      const ws = XLSX.utils.aoa_to_sheet(data);
      ws["!cols"] = [
        { wch: 8 }, // ID
        { wch: 20 }, // Fecha Registro
        { wch: 12 }, // Fecha Venta
        { wch: 15 }, // N° Factura
        { wch: 25 }, // Producto
        { wch: 15 }, // Código Producto
        { wch: 15 }, // N° Serie
        { wch: 25 }, // Asesor
        { wch: 12 }, // Cédula
        { wch: 20 }, // Llave BRE-B
        { wch: 25 }, // Distribuidor
        { wch: 12 }, // Estado
        { wch: 35 }, // Observaciones
        { wch: 60 }, // Link Foto
      ];

      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, "Ventas");
      XLSX.writeFile(wb, `ventas_${getTimestamp()}.xlsx`);
      console.log(`✅ Exportadas ${sales.length} ventas a Excel`);
    }

    // ===== EVENT LISTENERS DE EXPORTACIÓN =====

    // Toggle export menu
    if (exportBtn) {
      exportBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        if (exportMenu) {
          exportMenu.classList.toggle("show");
        }
      });
    }

    // Cerrar menu al hacer click fuera
    document.addEventListener("click", () => {
      if (exportMenu && exportMenu.classList.contains("show")) {
        exportMenu.classList.remove("show");
      }
    });

    // Manejar selección de formato
    if (exportMenu) {
      exportMenu.querySelectorAll("button").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          e.stopPropagation();
          const format = btn.getAttribute("data-format");

          if (currentFilteredSales.length === 0) {
            alert("No hay ventas para exportar");
            return;
          }

          if (format === "excel") {
            btn.disabled = true;
            const orig = btn.textContent;
            btn.textContent = "⏳ Preparando...";
            exportMenu.classList.remove("show");
            await exportToExcel(currentFilteredSales);
            btn.disabled = false;
            btn.textContent = orig;
          } else if (format === "csv") {
            btn.disabled = true;
            const origC = btn.textContent;
            btn.textContent = "⏳ Preparando...";
            exportMenu.classList.remove("show");
            await exportToCSV(currentFilteredSales);
            btn.disabled = false;
            btn.textContent = origC;
          }
        });
      });
    }

    // Inicializar
    loadProducts();
    loadSales();

    // Exponer loadSales globalmente para que otros componentes puedan recargar
    window.reloadSalesTable = loadSales;
  })();
</script>
