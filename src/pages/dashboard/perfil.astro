---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import Card from "../../components/Card.astro";
import AnimatedCard from "../../components/AnimatedCard.astro";
---

<DashboardLayout title="Mi Perfil">
  <div class="profile-container">
    <div class="profile-header">
      <h1>Mi Perfil</h1>
      <p class="subtitle">Información personal y laboral</p>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="state-message">
      <div class="spinner"></div>
      <p>Cargando perfil...</p>
    </div>

    <!-- Error State -->
    <div id="error-state" class="state-message" style="display: none;">
      <p class="error-text">Error al cargar el perfil</p>
    </div>

    <!-- Profile Content -->
    <div id="profile-content" class="profile-grid" style="display: none;">
      <!-- Información Personal -->
      <Card title="Información Personal">
        <div class="info-grid">
          <div class="info-field">
            <span class="field-label">Nombre Completo</span>
            <p id="nombre-completo">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Tipo de Documento</span>
            <p id="tipo-documento">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Número de Documento</span>
            <p id="numero-documento">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Cédula</span>
            <p id="cedula">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Fecha de Nacimiento</span>
            <p id="fecha-nacimiento">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Ciudad de Residencia</span>
            <p id="ciudad-residencia">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Departamento</span>
            <p id="departamento">-</p>
          </div>
        </div>
      </Card>

      <!-- Información de Contacto -->
      <Card title="Información de Contacto">
        <div class="info-grid">
          <div class="info-field">
            <span class="field-label">Correo Electrónico</span>
            <p id="correo">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">WhatsApp</span>
            <p id="whatsapp">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Teléfono</span>
            <p id="telefono">-</p>
          </div>
        </div>
      </Card>

      <!-- Información Laboral -->
      <Card title="Información Laboral">
        <div class="info-grid">
          <div class="info-field">
            <span class="field-label">Distribuidor</span>
            <p id="nombre-distribuidor">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Ciudad del Punto de Venta</span>
            <p id="ciudad-punto-venta">-</p>
          </div>
          <div class="info-field full-width">
            <span class="field-label">Dirección del Punto de Venta</span>
            <p id="direccion-punto-venta">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Cargo</span>
            <p id="cargo">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Antigüedad</span>
            <p id="antiguedad">-</p>
          </div>
        </div>
      </Card>

      <!-- Datos de Cuenta -->
      <AnimatedCard id="datos-cuenta-card" title="Datos de Cuenta">
        <div class="info-grid">
          <div class="info-field">
            <span class="field-label">Rol</span>
            <p id="rol" class="badge">-</p>
          </div>
          <div class="info-field">
            <span class="field-label">Estado de Cuenta</span>
            <p id="estado-cuenta" class="badge">-</p>
          </div>
          <div class="info-field">
            <div class="doc-field-header">
              <span class="field-label">Nequi</span>
              <button class="doc-edit-btn" data-doc="llave_breb" title="Editar número Nequi">
                <svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
              </button>
            </div>
            <p id="llave-breb">-</p>
            <div id="llave_breb-edit-form" class="doc-edit-form" style="display:none">
              <input type="text" id="llave_breb-input" placeholder="Número Nequi" class="doc-text-input" />
              <p class="form-helper-text warning" style="font-size:0.78rem;margin:0">⚠️ Debe coincidir con tu nombre completo.</p>
              <div class="doc-edit-actions">
                <button class="doc-save-btn" data-doc="llave_breb">Guardar</button>
                <button class="doc-cancel-btn" data-doc="llave_breb">Cancelar</button>
              </div>
              <p class="doc-status" id="llave_breb-status"></p>
            </div>
          </div>
          <!-- Certificado Nequi -->
          <div class="info-field">
            <div class="doc-field-header">
              <span class="field-label">Certificado Nequi</span>
              <button class="doc-edit-btn" data-doc="certificado" title="Actualizar certificado Nequi">
                <svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
              </button>
            </div>
            <div id="certificado-container">
              <span style="color:var(--color-text-secondary);font-size:0.85rem">No adjuntado</span>
            </div>
            <div id="certificado-edit-form" class="doc-edit-form" style="display:none">
              <input type="file" id="certificado-input" accept=".jpg,.jpeg,.png,.pdf" class="doc-file-input" />
              <label for="certificado-input" class="doc-file-label" id="certificado-file-label">Seleccionar archivo (JPG, PNG o PDF, máx 5MB)</label>
              <div class="doc-edit-actions">
                <button class="doc-save-btn" data-doc="certificado">Guardar</button>
                <button class="doc-cancel-btn" data-doc="certificado">Cancelar</button>
              </div>
              <p class="doc-status" id="certificado-status"></p>
            </div>
          </div>

          <!-- RUT -->
          <div class="info-field">
            <div class="doc-field-header">
              <span class="field-label">RUT</span>
              <button class="doc-edit-btn" data-doc="rut" title="Editar número RUT">
                <svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
              </button>
            </div>
            <p id="rut">-</p>
            <div id="rut-edit-form" class="doc-edit-form" style="display:none">
              <input type="text" id="rut-input" placeholder="Número RUT" class="doc-text-input" />
              <div class="doc-edit-actions">
                <button class="doc-save-btn" data-doc="rut">Guardar</button>
                <button class="doc-cancel-btn" data-doc="rut">Cancelar</button>
              </div>
              <p class="doc-status" id="rut-status"></p>
            </div>
          </div>

          <!-- Certificado RUT -->
          <div class="info-field">
            <div class="doc-field-header">
              <span class="field-label">Certificado RUT</span>
              <button class="doc-edit-btn" data-doc="certificado_rut" title="Actualizar certificado RUT">
                <svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
              </button>
            </div>
            <div id="certificado-rut-container">
              <span style="color:var(--color-text-secondary);font-size:0.85rem">No adjuntado</span>
            </div>
            <div id="certificado_rut-edit-form" class="doc-edit-form" style="display:none">
              <input type="file" id="certificado_rut-input" accept=".jpg,.jpeg,.png,.pdf" class="doc-file-input" />
              <label for="certificado_rut-input" class="doc-file-label" id="certificado_rut-file-label">Seleccionar archivo (JPG, PNG o PDF, máx 5MB)</label>
              <div class="doc-edit-actions">
                <button class="doc-save-btn" data-doc="certificado_rut">Guardar</button>
                <button class="doc-cancel-btn" data-doc="certificado_rut">Cancelar</button>
              </div>
              <p class="doc-status" id="certificado_rut-status"></p>
            </div>
          </div>
          <div class="info-field">
            <span class="field-label">Fecha de Registro</span>
            <p id="fecha-registro">-</p>
          </div>
        </div>
      </AnimatedCard>
    </div>
  </div>
</DashboardLayout>

<style>
  .profile-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .profile-header {
    margin-bottom: 2rem;
  }

  .profile-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin: 0 0 0.5rem 0;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .state-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
  }

  .spinner {
    border: 3px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 1s linear infinite;
    margin-bottom: 1rem;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .error-text {
    color: #e57373;
    font-weight: 500;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 1.5rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .info-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .info-field.full-width {
    grid-column: 1 / -1;
  }

  .info-field .field-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }

  .info-field p {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-main);
    margin: 0;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    width: fit-content;
  }

  .badge.active {
    background-color: rgba(56, 161, 105, 0.2);
    color: #68d391;
  }

  .badge.inactive {
    background-color: rgba(229, 62, 62, 0.2);
    color: #fc8181;
  }

  .badge.admin {
    background-color: rgba(159, 122, 234, 0.2);
    color: #b794f6;
  }

  .badge.asesor {
    background-color: rgba(66, 153, 225, 0.2);
    color: #63b3ed;
  }

  @media (max-width: 768px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Edición inline de documentos ── */
  .doc-field-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
  }
  .doc-edit-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.15rem;
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    transition: color 0.2s;
    border-radius: var(--radius-sm);
  }
  .doc-edit-btn:hover { color: var(--color-accent); }

  .doc-edit-form {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .doc-file-input { display: none; }
  .doc-file-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border: 1.5px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-cardb);
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    word-break: break-all;
  }
  .doc-file-label:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .doc-text-input {
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-bg-card);
    color: var(--color-text-main);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .doc-text-input:focus { border-color: var(--color-accent); }
  .doc-edit-actions {
    display: flex;
    gap: 0.4rem;
  }
  .doc-save-btn {
    background: rgba(72,187,120,0.15);
    color: #68d391;
    border: 1px solid rgba(72,187,120,0.3);
    border-radius: var(--radius-sm);
    padding: 0.25rem 0.75rem;
    cursor: pointer;
    font-size: 0.8rem;
    transition: background 0.2s;
  }
  .doc-save-btn:hover { background: rgba(72,187,120,0.3); }
  .doc-save-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .doc-cancel-btn {
    background: rgba(245,101,101,0.1);
    color: #fc8181;
    border: 1px solid rgba(245,101,101,0.2);
    border-radius: var(--radius-sm);
    padding: 0.25rem 0.75rem;
    cursor: pointer;
    font-size: 0.8rem;
    transition: background 0.2s;
  }
  .doc-cancel-btn:hover { background: rgba(245,101,101,0.2); }
  .doc-status {
    font-size: 0.8rem;
    margin: 0;
    min-height: 1.1em;
  }
  .doc-status.success { color: #68d391; }
  .doc-status.error   { color: #fc8181; }
</style>

<script is:inline>
  (function () {
    const API_BASE =
      window.location.hostname === "localhost" ||
      window.location.hostname === "127.0.0.1"
        ? "http://localhost:8000"
        : window.location.origin + "/api";

    const loadingState = document.getElementById("loading-state");
    const errorState = document.getElementById("error-state");
    const profileContent = document.getElementById("profile-content");

    async function loadProfile() {

      try {
        const response = await fetch(`${API_BASE}/user/profile.php`, {
          credentials: "include",
          headers: {
          },
        });

        const data = await response.json();

        if (data.status === 200 && data.data) {
          displayProfile(data.data);
        } else if (response.status === 401) {
          localStorage.clear();
          window.location.href = "/login";
        } else {
          throw new Error(data.message || "Error al cargar perfil");
        }
      } catch (error) {
        console.error("Error:", error);
        showError();
      }
    }

    function displayProfile(user) {
      // Información Personal
      document.getElementById("nombre-completo").textContent =
        `${user.nombre || ""} ${user.apellido || ""}`.trim() || "-";
      document.getElementById("tipo-documento").textContent =
        user.tipo_documento || "-";
      document.getElementById("numero-documento").textContent =
        user.numero_documento || "-";
      document.getElementById("cedula").textContent = user.cedula || "-";
      document.getElementById("fecha-nacimiento").textContent =
        user.fecha_nacimiento
          ? new Date(user.fecha_nacimiento).toLocaleDateString("es-CO")
          : "-";
      document.getElementById("ciudad-residencia").textContent =
        user.ciudad_residencia || "-";
      document.getElementById("departamento").textContent =
        user.departamento || "-";

      // Información de Contacto
      document.getElementById("correo").textContent = user.correo || "-";
      document.getElementById("whatsapp").textContent = user.whatsapp || "-";
      document.getElementById("telefono").textContent = user.telefono || "-";

      // Información Laboral
      document.getElementById("nombre-distribuidor").textContent =
        user.nombre_distribuidor || "-";
      document.getElementById("ciudad-punto-venta").textContent =
        user.ciudad_punto_venta || "-";
      document.getElementById("direccion-punto-venta").textContent =
        user.direccion_punto_venta || "-";
      document.getElementById("cargo").textContent = user.cargo || "-";
      document.getElementById("antiguedad").textContent = user.antiguedad_meses
        ? `${user.antiguedad_meses} meses`
        : "-";

      // Datos de Cuenta
      const rolEl = document.getElementById("rol");
      rolEl.textContent = user.rol || "-";
      rolEl.classList.add(user.rol === "admin" ? "admin" : "asesor");

      const estadoEl = document.getElementById("estado-cuenta");
      estadoEl.textContent = user.activo ? "Activa" : "Inactiva";
      estadoEl.classList.add(user.activo ? "active" : "inactive");

      document.getElementById("llave-breb").textContent =
        user.llave_breb || "-";

      // Certificado Nequi
      const certContainer = document.getElementById("certificado-container");
      if (certContainer) {
        if (user.certificado) {
          certContainer.innerHTML = `
            <a
            <a
              href="#" onclick="event.preventDefault(); window.viewCertificate('${user.certificado}')"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.3rem 0.75rem;border-radius:var(--radius-md);border:1px solid var(--color-border);background:var(--color-bg-cardb);color:var(--color-text-secondary);font-size:0.8rem;text-decoration:none;transition:all 0.2s;"
              onmouseover="this.style.borderColor='var(--color-accent)';this.style.color='var(--color-accent)'"
              onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-secondary)'"
            >
              <svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem;flex-shrink:0">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
              </svg>
              Ver certificado
            </a>`;
        } else {
          certContainer.innerHTML = `<span style="color:var(--color-text-secondary);font-size:0.85rem">No adjuntado</span>`;
        }
      }

      // RUT
      document.getElementById("rut").textContent = user.rut || "-";

      // Certificado RUT
      const certRutContainer = document.getElementById("certificado-rut-container");
      if (certRutContainer) {
        if (user.certificado_rut) {
          certRutContainer.innerHTML = `
            <a
            <a
              href="#" onclick="event.preventDefault(); window.viewCertificate('${user.certificado_rut}')"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.3rem 0.75rem;border-radius:var(--radius-md);border:1px solid var(--color-border);background:var(--color-bg-cardb);color:var(--color-text-secondary);font-size:0.8rem;text-decoration:none;transition:all 0.2s;"
              onmouseover="this.style.borderColor='var(--color-accent)';this.style.color='var(--color-accent)'"
              onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-secondary)'"
            >
              <svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem;flex-shrink:0"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
              Ver certificado RUT
            </a>`;
        } else {
          certRutContainer.innerHTML = `<span style="color:var(--color-text-secondary);font-size:0.85rem">No adjuntado</span>`;
        }
      }

      document.getElementById("fecha-registro").textContent = user.created_at
        ? new Date(user.created_at).toLocaleDateString("es-CO")
        : "-";

      // Check missing docs for animation
      const missing = !user.rut || !user.llave_breb || !user.certificado || !user.certificado_rut;
      const card = document.getElementById("datos-cuenta-card");
      if (card) {
        if (missing) card.classList.add("active");
        else card.classList.remove("active");
      }

      showProfile();
    }

    function showProfile() {
      loadingState.style.display = "none";
      errorState.style.display = "none";
      profileContent.style.display = "grid";
    }

    function showError() {
      loadingState.style.display = "none";
      errorState.style.display = "flex";
      profileContent.style.display = "none";
    }

    loadProfile();
  })();
</script>

<script is:inline>
  /* ── Edición inline de documentos ── */
  (function () {
    const API_BASE =
      window.location.hostname === "localhost" ||
      window.location.hostname === "127.0.0.1"
        ? "http://localhost:8000"
        : window.location.origin + "/api";

    window.viewCertificate = async function(filename) {
      try {
        const res = await fetch(`${API_BASE}/files/signed_url.php`, {
          method: "POST"
          credentials: "include",,
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ file: filename, type: "certificado" }),
        });
        const data = await res.json();
        if (data.signed_url) {
          window.open(data.signed_url, "_blank", "noopener,noreferrer");
        } else {
          alert("No se pudo obtener el enlace del certificado.");
        }
      } catch (err) {
        alert("Error al abrir el certificado.");
      }
    };

    function certLink(filename, label) {
      return `<a href="#" onclick="event.preventDefault(); window.viewCertificate('${filename}')" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.3rem 0.75rem;border-radius:var(--radius-md);border:1px solid var(--color-border);background:var(--color-bg-cardb);color:var(--color-text-secondary);font-size:0.8rem;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--color-accent)';this.style.color='var(--color-accent)'" onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-secondary)'"><svg viewBox="0 0 20 20" fill="currentColor" style="width:0.9rem;height:0.9rem;flex-shrink:0"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>${label}</a>`;
    }

    function setStatus(docName, msg, type) {
      const el = document.getElementById(docName + "-status");
      if (el) { el.textContent = msg; el.className = "doc-status " + (type || ""); }
    }

    function hideForm(docName) {
      const form = document.getElementById(docName + "-edit-form");
      if (form) form.style.display = "none";
      setStatus(docName, "");
      const fi = document.getElementById(docName + "-input");
      if (fi) fi.value = "";
      const lbl = document.getElementById(docName + "-file-label");
      if (lbl) lbl.textContent = "Seleccionar archivo (JPG, PNG o PDF, máx 5MB)";
    }

    // Botones lápiz → abrir/cerrar formulario
    document.querySelectorAll(".doc-edit-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        var docName = btn.dataset.doc;
        var form = document.getElementById(docName + "-edit-form");
        if (!form) return;
        form.style.display = form.style.display === "none" ? "flex" : "none";
        setStatus(docName, "");
      });
    });

    // Mostrar nombre de archivo seleccionado
    ["certificado", "certificado_rut"].forEach(function(docName) {
      var input = document.getElementById(docName + "-input");
      var label = document.getElementById(docName + "-file-label");
      if (!input || !label) return;
      input.addEventListener("change", function() {
        label.textContent = (input.files && input.files[0])
          ? input.files[0].name
          : "Seleccionar archivo (JPG, PNG o PDF, máx 5MB)";
      });
    });

    // Cancelar
    document.querySelectorAll(".doc-cancel-btn").forEach(function(btn) {
      btn.addEventListener("click", function() { hideForm(btn.dataset.doc); });
    });

    // Guardar
    document.querySelectorAll(".doc-save-btn").forEach(function(btn) {
      btn.addEventListener("click", async function() {
        var docName = btn.dataset.doc;

        var fd = new FormData();
        var hasData = false;

        if (docName === "rut") {
          var val = (document.getElementById("rut-input") || {}).value || "";
          if (!val.trim()) { setStatus("rut", "Ingresa el número RUT.", "error"); return; }
          fd.append("rut", val.trim());
          hasData = true;
        } else if (docName === "llave_breb") {
          var val2 = (document.getElementById("llave_breb-input") || {}).value || "";
          if (!val2.trim()) { setStatus("llave_breb", "Ingresa el número Nequi.", "error"); return; }
          fd.append("llave_breb", val2.trim());
          hasData = true;
        } else {
          var fi = document.getElementById(docName + "-input");
          if (!fi || !fi.files || !fi.files[0]) { setStatus(docName, "Selecciona un archivo primero.", "error"); return; }
          fd.append(docName, fi.files[0]);
          hasData = true;
        }
        if (!hasData) return;

        btn.disabled = true;
        setStatus(docName, "Guardando...", "");

        try {
          var res = await fetch(API_BASE + "/user/update_documents.php", {
            method: "POST"
          credentials: "include",,
            credentials: "include",
            body: fd
          });
          var data = await res.json();
          if (data.status === 200) {
            setStatus(docName, "✓ Guardado correctamente.", "success");
            if (docName === "certificado" && data.certificado) {
              var c = document.getElementById("certificado-container");
              if (c) c.innerHTML = certLink(data.certificado, "Ver certificado");
            }
            if (docName === "certificado_rut" && data.certificado_rut) {
              var c2 = document.getElementById("certificado-rut-container");
              if (c2) c2.innerHTML = certLink(data.certificado_rut, "Ver certificado RUT");
            }
            if (docName === "rut" && data.rut !== undefined) {
              var p = document.getElementById("rut");
              if (p) p.textContent = data.rut || "-";
            }
            if (docName === "llave_breb" && data.llave_breb !== undefined) {
              var p2 = document.getElementById("llave-breb");
              if (p2) p2.textContent = data.llave_breb || "-";
            }
            setTimeout(function() { 
              hideForm(docName); 
              
              // Validate if animation should continue
              var eRut = document.getElementById("rut");
              var eNeq = document.getElementById("llave-breb");
              var eCert = document.getElementById("certificado-container");
              var eCertRut = document.getElementById("certificado-rut-container");
              
              var noRut = !eRut || eRut.textContent.trim() === "-";
              var noNeq = !eNeq || eNeq.textContent.trim() === "-";
              var noCert = !eCert || eCert.innerHTML.includes("No adjuntado");
              var noCertRut = !eCertRut || eCertRut.innerHTML.includes("No adjuntado");
              
              var cCard = document.getElementById("datos-cuenta-card");
              if (cCard) {
                if (noRut || noNeq || noCert || noCertRut) cCard.classList.add("active");
                else cCard.classList.remove("active");
              }
            }, 1500);
          } else {
            setStatus(docName, data.message || "Error al guardar.", "error");
          }
        } catch (e) {
          setStatus(docName, "Error de conexión.", "error");
        } finally {
          btn.disabled = false;
        }
      });
    });
  })();
</script>
